<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<!--
  Unit tests run unconditionally (no device/Appium needed). Android needs
  a running Appium server + emulator/device — see README.md and
  apps/README.md. There is no iOS test entry: the iOS page objects are
  unverified locator guesses (see apps/README.md), not something to run
  by default.
-->
<suite name="Mobile Test Suite">

    <test name="Unit Tests">
        <classes>
            <class name="com.automation.utils.SwipeHelperTest"/>
        </classes>
    </test>

    <test name="Android Tests">
        <parameter name="platform" value="android"/>
        <classes>
            <class name="com.automation.tests.LoginTest"/>
        </classes>
    </test>

</suite>
